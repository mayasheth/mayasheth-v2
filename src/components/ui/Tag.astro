---
export interface Props {
  /** CSS color value, e.g. "var(--color-accent-3)". Defaults to content-3 (blue). */
  color?: string;
  textCase?: "uppercase" | "lowercase" | "normal";
  as?: "span" | "button";
  class?: string;
  [key: `data-${string}`]: string | undefined;
}

const {
  color,
  textCase = "uppercase",
  as: Element = "span",
  class: className = "",
  ...rest
} = Astro.props;

const caseClass = { uppercase: "uppercase", lowercase: "lowercase", normal: "" }[textCase];
const focusClass = Element === "button" ? "focus-outline" : "";

const classes = ["tag-frost font-base rounded-full px-2 py-1 text-sm", caseClass, focusClass, className]
  .filter(Boolean)
  .join(" ");

const inlineStyle = color ? `--tag-color: ${color}` : undefined;
---

<Element class={classes} style={inlineStyle} {...rest}>
  <slot />
</Element>
