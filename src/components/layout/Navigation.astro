---
import { Icon } from "astro-icon/components";
import SearchButton from "@/components/search/SearchButton.astro";
import MobileMenu from "@/components/layout/MobileMenu.astro";
import PawMark from "@/components/ui/PawMark.astro";
import { NAV_ITEMS } from "@/data/navData";

const navbarClasses =
  "flex items-center soft-transition group-hover:font-semibold group-hover:text-content-2 focus-outline-rounded";
const dropdownClasses =
  "block px-4 py-1 font-header soft-transition hover:font-semibold hover:text-content-2 focus-outline";
---

<header class="glass bg-surface-0/70 border-b border-pale-grey/10 sticky top-0 z-50 py-2 px-3">
  <div class="mx-auto flex max-w-6xl items-center justify-between">
    <!-- Left: PawMark logo + site name -->
    <div class="flex items-center gap-2">
      <a href="/" aria-label="maya sheth — home">
        <PawMark size="40px" />
      </a>
      <a
        href="/"
        class="text-content-3 soft-transition hover:text-content-2 focus-outline-rounded font-serif text-xl font-bold"
      >maya sheth</a>
    </div>

    <!-- Desktop menu -->
    <nav
      aria-label="Main navigation"
      class="font-header text-content-3 hidden items-center space-x-6 text-base font-light tracking-wide md:flex"
    >
      {
        NAV_ITEMS.map((item) => (
          <div class="group relative">
            <button type="button" class={navbarClasses}>
              <span class="hover-stable-fw" data-text={item.label}>{item.label}</span>
              {item.icon && (
                <Icon
                  name={item.icon}
                  class="soft-transition ml-1 h-4 w-4 group-hover:-scale-100"
                />
              )}
            </button>
            <div class="glass bg-surface-0/70 border border-pale-grey/10 absolute left-1/2 my-2 hidden w-auto -translate-x-1/2 rounded-md py-1 text-center group-hover:block before:absolute before:inset-x-0 before:-top-2 before:h-2 before:content-['']">
              {item.children.map((child) => (
                <a href={child.href} class={dropdownClasses}>
                  <span class="hover-stable-fw" data-text={child.label}>{child.label}</span>
                </a>
              ))}
            </div>
          </div>
        ))
      }
      <!-- Search button (desktop) -->
      <SearchButton id="search-trigger" />
    </nav>

    <!-- Mobile: icons only (search + menu), right aligned -->
    <MobileMenu navItems={NAV_ITEMS} mode="icons" />
  </div>

  <!-- Mobile: dropdown menu (always below header bar), hidden on desktop -->
  <MobileMenu navItems={NAV_ITEMS} mode="dropdown" />

</header>
