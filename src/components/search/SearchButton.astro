---
// src/components/SearchButton.astro
import { Icon } from "astro-icon/components";
const { id = "search-trigger", size = "h-6 w-6", label } = Astro.props;
---

<button
  id={id}
  class="group flex items-center rounded-full bg-surface-3 px-4 py-2 text-content-2 soft-transition hover:bg-surface-4 hover:text-content-1 focus-outline"
  aria-label="Open search (⌘K)"
>
  {
    label ? (
      <>
        <Icon name="mdi--magnify" class={`${size} soft-transition`} />
        <span class="font-header ml-2 text-base font-semibold tracking-wide">
          {label}
        </span>
      </>
    ) : (
      <>
        <Icon name="mdi--magnify" class="h-4 w-4" aria-hidden="true" />
        <span class="flex items-center gap-0.5 ml-1.5" aria-hidden="true">
          <Icon name="mdi--apple-keyboard-command" class="h-3.5 w-3.5" />
          <span class="font-mono text-sm font-semibold leading-none">K</span>
        </span>
      </>
    )
  }
</button>
