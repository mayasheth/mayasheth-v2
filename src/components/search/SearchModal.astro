---
// src/components/SearchModal.astro
---

<div
  id="search-modal"
  class="fixed inset-0 z-[999] hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Site search"
>
  <!-- Modal content -->
  <div class="relative flex min-h-screen items-center justify-center p-4">
    <div
      id="search-modal-content"
      class="glass bg-surface-0/88 border border-pale-grey/10 relative z-[1000] flex max-h-[72vh] w-full max-w-full flex-col overflow-hidden rounded-2xl p-5 sm:max-w-3/4 md:max-w-2/3 lg:max-w-1/2"
    >
      <button
        id="close-search-modal"
        class="text-content-3 hover:text-content-1 soft-transition absolute top-3 right-3 z-[1001] w-7 h-7 flex items-center justify-center rounded-full focus-outline-rounded text-lg leading-none"
        aria-label="Close search"
      >&times;</button>

      <!-- Pagefind UI container -->
      <div id="modal-search-field" class="flex flex-grow flex-col overflow-hidden"></div>
    </div>
  </div>
</div>
