---
// Server-side code, as before
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import MasonryGrid from "@/components/ui/MasonryGrid.astro";
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";

const titleShort = "art";
const titleFull = "artwork";

const artwork = await getCollection("artwork");
const artworkItems = artwork.map((item) => item.data);
artworkItems.sort((a, b) =>
  new Date(b.created) > new Date(a.created) ? 1 : -1,
);

const allTags = [...new Set(artworkItems.flatMap((a) => a.art_tags ?? []))]
  .map(formatTag)
  .sort();

function formatTag(tag: string): string {
  if (!tag) return "";
  return tag.replace(/-/g, " ");
}

const imageImports = import.meta.glob<{ default: ImageMetadata }>(
  "../../content/300-collections/portfolio/images/*",
);

const artworkItemsWithImports = await Promise.all(
  artworkItems.map(async (item) => {
    let imgData = null;
    const imageFileName = item.image
      ? item.image.replace(/^.*images\//, "")
      : "";
    const globKey = `../../content/300-collections/portfolio/images/${imageFileName}`;
    if (imageImports[globKey]) {
      imgData = (await imageImports[globKey]()).default;
    } else {
      console.warn("Image not found via import.meta.glob mapping:", globKey);
    }
    return { ...item, imgData };
  }),
);
---

<BaseLayout titleShort={titleShort} titleFull={titleFull}>
  <div class="container mx-auto px-4 py-6">
    <!-- Filter Controls -->
    <div
      class="mx-auto flex max-w-3/4 flex-wrap items-center justify-center gap-2 pb-6 text-base md:gap-4"
    >
      <span class="font-base text-content-0 font-semibold">filter</span>
      {
        allTags.map((tag) => (
          <button
            class="filter-button px-2 py-1 rounded-full bg-surface-1 text-content-2 text-sm font-base font-light lowercase soft-transition focus-outline"
            data-tag={tag}
            type="button"
            aria-pressed="false"
          >
            {tag}
          </button>
        ))
      }
    </div>

    <!-- Masonry List -->
    <MasonryGrid colsLg={5} class="mx-auto max-w-3/4">
      {
        artworkItemsWithImports.map((item, index) => (
          <masonry-item
            tabindex="0"
            role="button"
            class="group relative mb-2 h-auto w-full cursor-pointer rounded-md focus-outline-rounded md:mb-3"
            data-tags={item.art_tags?.map(formatTag).join(",") ?? ""}
            data-title={item.title ?? ""}
            data-description={item.description ?? ""}
            data-year={item.created ? item.created.getFullYear() : ""}
            data-inspiration={item.inspiration ?? ""}
          >
            {item.imgData && (
              <>
                <Image
                  src={item.imgData}
                  alt={item.description ?? item.title ?? "artwork"}
                  width={600}
                  draggable="false"
                  loading={index < 8 ? "eager" : "lazy"}
                  class="h-auto w-full rounded-md"
                />
                <div class="bg-content-0 soft-transition absolute inset-0 flex flex-col items-center justify-center rounded-md opacity-0 hover:opacity-90">
                  <p class="text-surface-3 soft-transition px-4 text-center text-base font-semibold lowercase opacity-0 group-hover:opacity-100">
                    {item.title}
                  </p>
                  <p class="text-surface-4 font-mono text-base font-medium">
                    {item.created.getFullYear()}
                  </p>
                  {item.inspiration && (
                    <a
                      class="font-base text-content-4 hover:text-content-3 soft-transition text-center text-sm font-medium italic opacity-0 group-hover:opacity-100"
                      target="_blank"
                      href={item.inspiration}
                    >
                      inspiration
                    </a>
                  )}
                </div>
              </>
            )}
          </masonry-item>
        ))
      }
    </MasonryGrid>
  </div>

  <div
    id="gallery-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
    class="bg-surface-0/60 hide-modal fixed inset-0 z-50 flex items-center justify-center backdrop-blur-xs"
    tabindex="-1"
  >
    <button
      id="modal-prev"
      aria-label="Previous artwork"
      class="absolute left-3 top-1/2 z-10 hidden -translate-y-1/2 rounded-full bg-surface-0/70 p-2 text-xl text-content-2 soft-transition hover:bg-surface-2 hover:text-content-1 focus-outline-rounded md:left-5 md:p-3"
    >←</button>

    <div
      id="gallery-modal-content"
      class="bg-surface-1 relative max-h-[92vh] w-full max-w-lg overflow-y-auto rounded-xl md:max-w-2xl"
    >
      <!-- Dynamic content injected by JS -->
    </div>

    <button
      id="modal-next"
      aria-label="Next artwork"
      class="absolute right-3 top-1/2 z-10 hidden -translate-y-1/2 rounded-full bg-surface-0/70 p-2 text-xl text-content-2 soft-transition hover:bg-surface-2 hover:text-content-1 focus-outline-rounded md:right-5 md:p-3"
    >→</button>
  </div>

  <script>
    // Filter logic (same as before)
    const buttons = document.querySelectorAll(".filter-button");
    const items = document.querySelectorAll("masonry-item");
    let activeFilter: string | null = null;

    function formatTag(tag: string): string {
      if (!tag) return "";
      const formatted = tag.replace(/-/g, " ");
      return formatted;
    }

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const tag = button.getAttribute("data-tag");
        if (activeFilter === tag) {
          activeFilter = null;
        } else {
          activeFilter = tag;
        }
        // Update buttons
        buttons.forEach((b) => {
          const bTag = b.getAttribute("data-tag");
          if (activeFilter === bTag) {
            b.setAttribute("aria-pressed", "true");
            b.classList.add("bg-surface-3", "hover:bg-surface-4", "text-content-1");
            b.classList.remove("bg-surface-1", "hover:bg-surface-2", "text-content-2");
          } else {
            b.setAttribute("aria-pressed", "false");
            b.classList.add("bg-surface-1", "hover:bg-surface-2", "text-content-2");
            b.classList.remove("bg-surface-3", "hover:bg-surface-4", "text-content-1");
          }
        });
        // Filter items (works with custom element tags!)
        items.forEach((item) => {
          const itemTags = item
            .getAttribute("data-tags")
            ?.split(",")
            .map(formatTag);
          if (!activeFilter || (itemTags && itemTags.includes(activeFilter))) {
            item.classList.remove("hidden");
          } else {
            item.classList.add("hidden");
          }
        });
      });
    });

    (function () {
      const modal = document.getElementById("gallery-modal");
      const modalContent = document.getElementById("gallery-modal-content");
      const prevBtn = document.getElementById("modal-prev");
      const nextBtn = document.getElementById("modal-next");
      let lastFocused: Element | null = null;
      let filteredItems: Element[] = [];
      let currentIndex = 0;

      // Tailwind class strings consolidated for scanner
      const S = {
        closeBtn: "absolute top-3 right-3 px-2 text-xl md:text-2xl font-base font-semibold text-content-3 hover:text-content-2 hover-pop soft-transition focus-outline-rounded",
        imgWrap:  "pt-4 px-4",
        img:      "w-full rounded-xl object-contain max-h-[62vh] md:max-h-[46vh]",
        meta:     "px-5 py-4 md:px-6 md:py-5 text-center",
        title:    "font-header text-lg font-semibold text-content-1 lowercase leading-tight",
        year:     "block mt-0.5 font-mono text-sm text-content-3",
        desc:     "mt-2 text-sm font-base font-light text-content-2 lowercase",
        inspoRow: "mt-2",
        inspo:    "text-sm italic text-content-3 hover:text-content-2 soft-transition focus-outline-rounded",
        tagsWrap: "mt-3 flex flex-wrap gap-1.5 justify-center",
        tag:      "inline-block rounded-full bg-surface-2 hover:bg-surface-3 px-1.5 py-0.5 font-base text-[0.65rem] text-content-3 hover:text-content-2 soft-transition uppercase",
      };

      function showItem(index: number, animate = false) {
        function doUpdate() {
          currentIndex = index;
          const item = filteredItems[index];
          const imgSrc = item.querySelector("img")?.src ?? "";
          const title = item.getAttribute("data-title") || "";
          const desc = item.getAttribute("data-description") || "";
          const tags = item.getAttribute("data-tags")?.split(",").filter(Boolean) || [];
          const year = item.getAttribute("data-year") || "";
          const inspiration = item.getAttribute("data-inspiration") || "";

          /* @ts-ignore */
          modalContent.innerHTML = `
            <button id="modal-close" aria-label="Close" class="${S.closeBtn}">&times;</button>
            <div class="${S.imgWrap}">
              <img src="${imgSrc}" alt="${title || desc || "artwork"}" class="${S.img}" draggable="false" />
            </div>
            <div class="${S.meta}">
              <h2 id="modal-title" class="${S.title}">${title}</h2>
              ${year ? `<span class="${S.year}">${year}</span>` : ""}
              ${desc ? `<p class="${S.desc}">${desc}</p>` : ""}
              ${inspiration ? `<div class="${S.inspoRow}"><a href="${inspiration}" target="_blank" rel="noopener" class="${S.inspo}">inspiration ↗</a></div>` : ""}
              ${tags.length ? `<div class="${S.tagsWrap}">${tags.map((t: string) => `<span class="${S.tag}">${t}</span>`).join("")}</div>` : ""}
            </div>
          `;
          /* @ts-ignore */
          modalContent.querySelector("#modal-close")?.addEventListener("click", closeModal);
          /* @ts-ignore */
          if (animate) modalContent.style.opacity = "";

          const showNav = filteredItems.length > 1;
          prevBtn?.classList.toggle("hidden", !showNav);
          nextBtn?.classList.toggle("hidden", !showNav);
        }

        if (animate) {
          /* @ts-ignore */
          modalContent.style.opacity = "0";
          setTimeout(doUpdate, 130);
        } else {
          doUpdate();
        }
      }

      function openModal(item: Element) {
        filteredItems = [...document.querySelectorAll("masonry-item:not(.hidden)")];
        currentIndex = filteredItems.indexOf(item);
        lastFocused = item;
        showItem(currentIndex);
        /* @ts-ignore */
        modal.classList.remove("hide-modal");
        /* @ts-ignore */
        setTimeout(() => { (modalContent.querySelector("#modal-close") as HTMLElement)?.focus(); }, 100);
      }

      function closeModal() {
        /* @ts-ignore */
        modal.classList.add("hide-modal");
        if (lastFocused) (lastFocused as HTMLElement).focus();
        setTimeout(() => {
          /* @ts-ignore */
          modalContent.innerHTML = "";
          prevBtn?.classList.add("hidden");
          nextBtn?.classList.add("hidden");
        }, 200);
      }

      document.querySelectorAll("masonry-item").forEach((item) => {
        item.addEventListener("click", () => openModal(item));
        item.addEventListener("keydown", (e) => {
          if ((e as KeyboardEvent).key === "Enter" || (e as KeyboardEvent).key === " ") {
            openModal(item);
          }
        });
      });

      prevBtn?.addEventListener("click", () => {
        if (!filteredItems.length) return;
        showItem((currentIndex - 1 + filteredItems.length) % filteredItems.length, true);
      });
      nextBtn?.addEventListener("click", () => {
        if (!filteredItems.length) return;
        showItem((currentIndex + 1) % filteredItems.length, true);
      });

      /* @ts-ignore */
      modal.addEventListener("mousedown", (e) => { if (e.target === modal) closeModal(); });

      document.addEventListener("keydown", (e) => {
        /* @ts-ignore */
        if (modal.classList.contains("hide-modal")) return;
        if (e.key === "Escape") closeModal();
        if (e.key === "ArrowLeft" && filteredItems.length > 1)
          showItem((currentIndex - 1 + filteredItems.length) % filteredItems.length, true);
        if (e.key === "ArrowRight" && filteredItems.length > 1)
          showItem((currentIndex + 1) % filteredItems.length, true);
      });

      // Prevent right-click save on artwork images
      document.addEventListener("contextmenu", (e) => {
        if (e.target instanceof HTMLImageElement) e.preventDefault();
      });
    })();
  </script>
</BaseLayout>

<style>
  /* Modal styling */
  .hide-modal {
    opacity: 0;
    pointer-events: none;
  }
  #gallery-modal {
    opacity: 1;
    transition: opacity 0.15s;
  }
  #gallery-modal.hide-modal {
    opacity: 0;
  }
  #gallery-modal-content {
    transition: transform 0.2s ease-out, opacity 0.15s ease;
  }
  #gallery-modal.hide-modal #gallery-modal-content {
    transform: translateY(10px);
  }
  /* Discourage right-click save / drag-to-desktop */
  masonry-item img,
  #gallery-modal img {
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }
</style>
