  Tanzania: [17, 16],
  Thailand: [24, 10],
  "Timor-Leste": [25, 14],
  Togo: [14, 14],
  Tonga: [28, 19],
  "Trinidad and Tobago": [7, 9], // tile has "Trinidad & Tobago"
  Tunisia: [14, 11],
  Turkey: [18, 7],
  Turkmenistan: [22, 7],
  Tuvalu: [27, 18],
  // U
  Uganda: [16, 15],
  Ukraine: [17, 5],
  "United Arab Emirates": [20, 10],
  "United Kingdom": [11, 4], // tile has "Great Britain and Northern Ireland"
