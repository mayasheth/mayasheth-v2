const GRID_COLS = 30;
const GRID_ROWS = 24;

type TileStatus = "complete" | "in-progress" | "planned";

function getStatus(data: { book_status: string; music_status: string }): TileStatus {
  if (data.book_status === "DONE" && data.music_status === "DONE") return "complete";
  if (data.book_status === "DONE" || data.book_status === "IN-PROGRESS") return "in-progress";
  return "planned";
}

// Static class strings so Tailwind's scanner picks them up
const tileBase =
  "atw-tile relative flex flex-col items-center justify-center rounded-sm focus:outline-none focus-visible:ring-1 focus-visible:ring-pale-grey/40";
const tileClasses: Record<TileStatus, string> = {
  complete: "tile-e-complete",
  "in-progress": "tile-e-in-progress",
  planned: "tile-e-planned",
};
const dotBookClasses: Record<string, string> = {
  DONE: "bg-accent-2",
  "IN-PROGRESS": "bg-accent-1",
  other: "bg-content-4/40",
};
const dotMusicDoneClass = "bg-accent-2";
const dotMusicOtherClass = "bg-content-4/40";

const atw = await getCollection("atw");

// Counts for tagline (mirrors original around-the-world.astro logic)
const { bothComplete, bookOnlyComplete, bookIdea, bookIncomplete } = atw.reduce(
  (acc, item) => {
    if (item.data.book_status === "DONE" && item.data.music_status === "DONE") {
      acc.bothComplete++;
    } else if (item.data.book_status === "DONE") {
      acc.bookOnlyComplete++;
    } else if (item.data.book_ideas !== null && item.data.book_ideas?.length !== 0) {
      acc.bookIdea++;
    } else {
      acc.bookIncomplete++;
    }
    return acc;
  },
  { bothComplete: 0, bookOnlyComplete: 0, bookIdea: 0, bookIncomplete: 0 },
);
const bookComplete = bothComplete + bookOnlyComplete;

const positioned = atw
  .filter((e) => Boolean(COORDS[e.data.location]))
  .map((e) => ({
    entry: e,
    coords: COORDS[e.data.location]!,
    status: getStatus(e.data as { book_status: string; music_status: string }),
  }));

const overflow = atw
  .filter((e) => !COORDS[e.data.location])
  .map((e) => ({
    entry: e,
    status: getStatus(e.data as { book_status: string; music_status: string }),
  }));

// Mobile layout — all entries alphabetical, grouped by status
const allSorted = [...atw]
  .sort((a, b) => a.data.location.localeCompare(b.data.location))
  .map((e) => ({
    entry: e,
    status: getStatus(e.data as { book_status: string; music_status: string }),
  }));
const mobileGroups = [
  { label: "complete", dotClass: "bg-accent-2", entries: allSorted.filter((e) => e.status === "complete") },
  { label: "in progress", dotClass: "bg-accent-1", entries: allSorted.filter((e) => e.status === "in-progress") },
  { label: "planned", dotClass: "bg-content-4/40", entries: allSorted.filter((e) => e.status === "planned") },
];
---

<BaseLayout titleShort="worldly" titleFull="around the world">
  {/* Tagline */}
  <p class="text-content-1 text-center text-pretty">
    a quest to read a book (& listen to a song while i'm at it) for every country (or other major
    [subjective] territory) in the world
  </p>
  <p class="pb-6 text-center text-content-2">
    <span class="font-semibold">current status:</span> books read for
    <span class="font-mono text-lg font-semibold text-content-3 md:text-xl">{bookComplete}</span>
    locations; ideas for
    <span class="font-mono text-lg font-semibold text-content-3 md:text-xl">{bookIdea}</span>
    more;
    <span class="font-mono text-lg font-semibold text-content-3 md:text-xl">{bookIncomplete}</span>
    to go!
  </p>

  {/* Legend */}
  <div class="mb-6 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 font-base text-sm text-content-2 lowercase">
    <div class="flex items-center gap-1.5">
      <span class="tile-e-complete pointer-events-none inline-block h-3 w-3 flex-shrink-0 rounded-sm"></span>
      <span>complete</span>
    </div>
    <div class="flex items-center gap-1.5">
      <span class="tile-e-in-progress pointer-events-none inline-block h-3 w-3 flex-shrink-0 rounded-sm"></span>
      <span>in progress</span>
    </div>
    <div class="flex items-center gap-1.5">
      <span class="tile-e-planned pointer-events-none inline-block h-3 w-3 flex-shrink-0 rounded-sm"></span>
      <span>planned</span>
    </div>
    <div class="mx-2 hidden h-4 w-px bg-pale-grey/20 sm:block"></div>
    <div class="flex items-center gap-1">
      <span class="inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-accent-2"></span>
      <span>complete</span>
    </div>
    <div class="flex items-center gap-1">
      <span class="inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-accent-1"></span>
      <span>in progress</span>
    </div>
    <div class="flex items-center gap-1">
      <span class="inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-content-4/40"></span>
      <span>not started</span>
    </div>
    <span class="text-xs text-content-3">left dot = book &nbsp;|&nbsp; right = music</span>
  </div>

  {/* ── MOBILE LAYOUT: compact status groups ── */}
  <div class="w-full md:hidden">
    {mobileGroups.map(({ label, dotClass, entries }) => entries.length > 0 && (
      <div class="mb-5">
        <div class="mb-2 flex items-center gap-2">
          <span class={`h-1.5 w-1.5 flex-shrink-0 rounded-full ${dotClass}`}></span>
          <span class="font-base text-xs text-content-3 lowercase tracking-wide">{label} ({entries.length})</span>
        </div>
        <div class="grid grid-cols-2 gap-1">
          {entries.map(({ entry, status }) => {
            const flagCode = getFlagCode(entry.data.location);
            const bookStatus = entry.data.book_status as string;
            const musicStatus = entry.data.music_status as string;
            const bookDotClass = dotBookClasses[bookStatus] ?? dotBookClasses.other;
            const musicDotClass = musicStatus === "DONE" ? dotMusicDoneClass : dotMusicOtherClass;
            return (
              <a
                href={`/media/around-the-world/${entry.id}`}
                class={`${tileClasses[status]} relative flex flex-row items-center gap-1.5 rounded-md px-2 py-1.5 focus:outline-none focus-visible:ring-1 focus-visible:ring-pale-grey/40`}
                aria-label={entry.data.location}
              >
                {flagCode ? (
                  <span class={`fi fi-${flagCode} flex-shrink-0`} style="font-size:0.75rem;border-radius:1px;"></span>
                ) : (
                  <span class="flex-shrink-0 font-mono text-content-4" style="font-size:0.6rem;">{entry.data.location.slice(0, 2).toUpperCase()}</span>
                )}
                <span class="flex-1 truncate font-base text-xs lowercase text-content-2">{entry.data.location}</span>
                <div class="flex flex-shrink-0 gap-[2px]">
                  <span class={`block h-[3px] w-[3px] rounded-full ${bookDotClass}`}></span>
                  <span class={`block h-[3px] w-[3px] rounded-full ${musicDotClass}`}></span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    ))}
  </div>

  {/* Tile map + overflow in one scroll container so there's no gap between them */}
  <div class="hidden w-full overflow-x-auto md:block">
    <div style={`min-width:900px;width:100%;max-width:1300px;margin:0 auto;`}>
      <div
        id="atw-grid"
        style={`display:grid;grid-template-columns:repeat(${GRID_COLS},1fr);grid-template-rows:repeat(${GRID_ROWS},1fr);gap:2px;width:100%;aspect-ratio:${GRID_COLS}/${GRID_ROWS};`}
      >
        {positioned.map(({ entry, coords, status }) => {
          const [col, row] = coords;
          const flagCode = getFlagCode(entry.data.location);
          const bookStatus = entry.data.book_status as string;
          const musicStatus = entry.data.music_status as string;
          const bookDotClass = dotBookClasses[bookStatus] ?? dotBookClasses.other;
          const musicDotClass = musicStatus === "DONE" ? dotMusicDoneClass : dotMusicOtherClass;
          return (
            <a
              href={`/media/around-the-world/${entry.id}`}
              class={`${tileBase} ${tileClasses[status]}`}
              style={`grid-column:${col};grid-row:${row};`}
              aria-label={entry.data.location}
              data-location={entry.data.location}
              data-status={status}
              data-book-title={entry.data.book_title ?? ""}
              data-book-author={entry.data.book_author ?? ""}
              data-book-cover={entry.data.book_cover ?? ""}
              data-song={entry.data.music_song ?? ""}
              data-artist={entry.data.music_artist ?? ""}
              data-music-link={entry.data.music_link ?? ""}
              data-book-done={bookStatus === "DONE" ? "true" : "false"}
              data-music-done={musicStatus === "DONE" ? "true" : "false"}
            >
              {flagCode ? (
                <span class={`fi fi-${flagCode} block`} style="font-size:0.85rem;border-radius:1px;"></span>
              ) : (
                <span class="font-mono leading-none text-content-4" style="font-size:0.45rem;">
                  {entry.data.location.slice(0, 2).toUpperCase()}
                </span>
              )}
              <div class="absolute bottom-[3px] left-0 right-0 flex justify-center gap-[2px]">
                <span class={`block h-[3px] w-[3px] rounded-full ${bookDotClass}`}></span>
                <span class={`block h-[3px] w-[3px] rounded-full ${musicDotClass}`}></span>
              </div>
            </a>
          );
        })}
      </div>

      {/* Overflow strip — tucked directly below the grid, inside the same scroll wrapper */}
      {overflow.length > 0 && (
        <div class="mt-2 pb-2">
          <p class="mb-1.5 text-center font-base text-xs text-content-4 lowercase tracking-wide">
            other regions
          </p>
          <div class="flex flex-wrap justify-center gap-1.5">
            {overflow.map(({ entry, status }) => {
              const flagCode = getFlagCode(entry.data.location);
              const bookStatus = entry.data.book_status as string;
              const musicStatus = entry.data.music_status as string;
              const bookDotClass = dotBookClasses[bookStatus] ?? dotBookClasses.other;
              const musicDotClass =
                musicStatus === "DONE" ? dotMusicDoneClass : dotMusicOtherClass;
              return (
                <a
                  href={`/media/around-the-world/${entry.id}`}
                  class={`${tileBase} ${tileClasses[status]}`}
                  style="width:40px;height:40px;"
                  aria-label={entry.data.location}
                  data-location={entry.data.location}
                  data-status={status}
                  data-book-title={entry.data.book_title ?? ""}
                  data-book-author={entry.data.book_author ?? ""}
                  data-book-cover={entry.data.book_cover ?? ""}
                  data-song={entry.data.music_song ?? ""}
                  data-artist={entry.data.music_artist ?? ""}
                  data-music-link={entry.data.music_link ?? ""}
                  data-book-done={bookStatus === "DONE" ? "true" : "false"}
                  data-music-done={musicStatus === "DONE" ? "true" : "false"}
                >
                  {flagCode ? (
                    <span class={`fi fi-${flagCode} block`} style="font-size:0.85rem;border-radius:1px;"></span>
                  ) : (
                    <span class="font-mono leading-none text-content-4" style="font-size:0.45rem;">
                      {entry.data.location.slice(0, 2).toUpperCase()}
                    </span>
                  )}
                  <div class="absolute bottom-[3px] left-0 right-0 flex justify-center gap-[2px]">
                    <span class={`block h-[3px] w-[3px] rounded-full ${bookDotClass}`}></span>
                    <span class={`block h-[3px] w-[3px] rounded-full ${musicDotClass}`}></span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      )}
    </div>
  </div>

  {/* Hover tooltip */}
  <div
    id="atw-tooltip"
    class="pointer-events-none fixed z-50 hidden w-52 glass bg-surface-0/80 border border-pale-grey/10 rounded-xl p-3 shadow-xl"
    role="tooltip"
    aria-hidden="true"
  >
    <p id="atw-tt-location" class="font-header text-content-2 text-base font-light tracking-wide lowercase"></p>
    <div id="atw-tt-book" class="mt-2 hidden">
      <div class="flex items-start gap-2">
        <img
          id="atw-tt-cover"
          src=""
          alt=""
          class="hidden h-auto w-9 flex-shrink-0 rounded"
          loading="lazy"
        />
        <div class="min-w-0">
          <p id="atw-tt-title" class="wrap-anywhere text-xs font-semibold italic leading-snug lowercase text-content-1"></p>
          <p id="atw-tt-author" class="mt-0.5 text-xs lowercase text-content-3"></p>
        </div>
      </div>
    </div>
    <div id="atw-tt-music" class="mt-2 hidden border-t border-pale-grey/10 pt-2">
      <p id="atw-tt-song" class="text-xs font-semibold leading-snug lowercase text-content-2"></p>
      <p id="atw-tt-artist" class="mt-0.5 text-xs lowercase text-content-3"></p>
    </div>
    <p id="atw-tt-planned" class="mt-1 hidden text-xs italic lowercase text-content-4">exploring...</p>
  </div>
</BaseLayout>


<style>
  /*
    Option E — all three tiles use the same dark navy base color (btn-glass's base),
    interpolated at 0.10 / 0.30 / 0.55 opacity. Same backdrop-filter across all three
    so they feel like one coherent system. Transition speeds match btn-glass (700ms).
  */
  .tile-e-complete {
    background: oklch(17.5% 0.124 276 / 0.10);
    backdrop-filter: blur(16px) saturate(1.4) brightness(1.22);
    -webkit-backdrop-filter: blur(16px) saturate(1.4) brightness(1.22);
    border: 0.75px solid oklch(90.4% 0.017 264 / 0.20);
    transition: background 700ms ease-in-out, border-color 400ms ease;
  }
  .tile-e-complete:hover {
    background: oklch(17.5% 0.124 276 / 0.04);
    filter: brightness(1.06);
  }
  .tile-e-in-progress {
    background: oklch(17.5% 0.124 276 / 0.30);
    backdrop-filter: blur(16px) saturate(1.3) brightness(1.10);
    -webkit-backdrop-filter: blur(16px) saturate(1.3) brightness(1.10);
    border: 0.75px solid oklch(90.4% 0.017 264 / 0.20);
    transition: background 700ms ease-in-out, border-color 400ms ease;
  }
  .tile-e-in-progress:hover {
    background: oklch(17.5% 0.124 276 / 0.18);
    filter: brightness(1.04);
  }
  .tile-e-planned {
    background: oklch(17.5% 0.124 276 / 0.55);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border: 0.75px solid oklch(90.4% 0.017 264 / 0.20);
    transition: background 700ms ease-in-out, border-color 400ms ease;
  }
  .tile-e-planned:hover {
    background: oklch(17.5% 0.124 276 / 0.38);
  }
</style>

<script>
  const tooltip = document.getElementById("atw-tooltip")!;
  const ttLocation = document.getElementById("atw-tt-location")!;
  const ttBook = document.getElementById("atw-tt-book")!;
  const ttCover = document.getElementById("atw-tt-cover") as HTMLImageElement;
  const ttTitle = document.getElementById("atw-tt-title")!;
  const ttAuthor = document.getElementById("atw-tt-author")!;
  const ttMusic = document.getElementById("atw-tt-music")!;
  const ttSong = document.getElementById("atw-tt-song")!;
  const ttArtist = document.getElementById("atw-tt-artist")!;
  const ttPlanned = document.getElementById("atw-tt-planned")!;

  function positionTooltip(clientX: number, clientY: number) {
    const offset = 14;
    const vw = window.innerWidth;
    const vh = window.innerHeight;
    const tw = tooltip.offsetWidth || 208;
    const th = tooltip.offsetHeight || 120;
    let x = clientX + offset;
    let y = clientY + offset;
    if (x + tw > vw - 8) x = clientX - tw - offset;
    if (y + th > vh - 8) y = clientY - th - offset;
    tooltip.style.left = `${x}px`;
    tooltip.style.top = `${y}px`;
  }

  function showTooltip(tile: HTMLAnchorElement, clientX: number, clientY: number) {
    const d = tile.dataset;
    ttLocation.textContent = d.location ?? "";

    const hasBook = Boolean(d.bookTitle) && d.bookDone === "true";
    ttBook.classList.toggle("hidden", !hasBook);
    if (hasBook) {
      ttTitle.textContent = d.bookTitle ?? "";
      ttAuthor.textContent = d.bookAuthor ?? "";
      if (d.bookCover) {
        ttCover.src = d.bookCover;
        ttCover.alt = d.bookTitle ?? "";
        ttCover.classList.remove("hidden");
      } else {
        ttCover.classList.add("hidden");
      }
    }

    const hasMusic = Boolean(d.song) && d.musicDone === "true";
    ttMusic.classList.toggle("hidden", !hasMusic);
    if (hasMusic) {
      ttSong.textContent = `"${d.song}"`;
      ttArtist.textContent = `— ${d.artist}`;
    }

    ttPlanned.classList.toggle("hidden", d.status !== "planned");
    tooltip.classList.remove("hidden");
    positionTooltip(clientX, clientY);
  }

  document.querySelectorAll<HTMLAnchorElement>(".atw-tile").forEach((tile) => {
    tile.addEventListener("mouseenter", (e) => {
      showTooltip(tile, (e as MouseEvent).clientX, (e as MouseEvent).clientY);
    });
    tile.addEventListener("mousemove", (e) => {
      positionTooltip((e as MouseEvent).clientX, (e as MouseEvent).clientY);
    });
    tile.addEventListener("mouseleave", () => {
      tooltip.classList.add("hidden");
    });
    tile.addEventListener("focus", () => {
      const rect = tile.getBoundingClientRect();
      showTooltip(tile, rect.left + rect.width / 2, rect.bottom + 4);
    });
    tile.addEventListener("blur", () => {
      tooltip.classList.add("hidden");
    });
  });
</script>
