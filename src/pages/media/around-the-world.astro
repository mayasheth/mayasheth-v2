  // W — West Indies intentionally omitted (non-country region, will be removed from source)
  // Remaining overflow: Liechtenstein, Monaco, San Marino (microstates inside other countries;
  // no defensible tile position exists for them in the grid)
  // Y
  Yemen: [18, 11],
  // Z
  Zambia: [14, 18],
  Zimbabwe: [16, 18],
