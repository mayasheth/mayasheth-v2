---
import "@/styles/index.css";
import Navigation from "@/components/layout/Navigation.astro";
import Footer from "@/components/layout/Footer.astro";
import GradientBackground from "@/components/ui/GradientBackground.astro";
import { getCollection } from "astro:content";
import { homeContent } from "@/data/home-content-config.js";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { isImage } from "@/lib/helpers/media-info-helpers";
import type { ImageMetadata } from "astro";

function getQuoteClass(text: string) {
  const len = text.length;
  if (len < 60)  return "font-serif text-2xl font-extrabold text-content-4 leading-tight";
  if (len < 100) return "font-serif text-xl font-bold text-content-3 leading-tight";
  if (len < 140) return "font-base text-lg font-medium text-content-2 leading-snug";
  return "font-base text-base font-light text-content-1 leading-snug";
}

const artworkImageImports = import.meta.glob<{ default: ImageMetadata }>(
  "../content/300-collections/portfolio/images/*"
);

const allQuotes = await getCollection("quotes");
const allArtwork = await getCollection("artwork");
const featuredArtwork = await Promise.all(
  homeContent.artwork.map(async (id) => {
    const item = allArtwork.find((a) => a.id === id);
    if (!item?.data.image) return null;
    const fileName = item.data.image.replace(/^.*images\//, "");
    const globKey = `../content/300-collections/portfolio/images/${fileName}`;
    const imgData = artworkImageImports[globKey]
      ? (await artworkImageImports[globKey]()).default
      : null;
    return { id, title: item.data.title ?? null, imgData };
  })
).then((items) => items.filter(Boolean));

const featuredQuotes = homeContent.quotes
  .map(({ id, sourceDisplay }) => {
    const q = allQuotes.find((q) => q.id === id);
    if (!q) return null;
    return {
      words:  q.data.words,
      source: sourceDisplay ?? q.data.primary_source,
      href:   `/quotes/${id}`,
    };
  })
  .filter(Boolean);

const allMedia = await getCollection("media");
const featuredMedia = homeContent.media
  .map((id) => {
    const item = allMedia.find((m) => m.id === id);
    if (!item) return null;
    const src = item.data.link_to_source ?? "";
    return {
      id,
      title: item.data.title,
      author: item.data.author,
      href: `/media/${id}`,
      coverUrl: isImage(src) ? src : null,
    };
  })
  .filter(Boolean);

const currentInterests = homeContent.interests;
const currently = homeContent.currently;

const atw = await getCollection("atw");
const atwBookComplete = atw.filter(i => i.data.book_status === "DONE").length;
const atwBookIdea = atw.filter(i =>
  i.data.book_status !== "DONE" && i.data.book_ideas?.length
).length;
const atwToGo = atw.filter(i =>
  i.data.book_status !== "DONE" && !i.data.book_ideas?.length
).length;

const COUNTRY_ISO: Record<string, string> = {
  "Afghanistan":"AF","Albania":"AL","Algeria":"DZ","Andorra":"AD","Angola":"AO",
  "Antigua and Barbuda":"AG","Argentina":"AR","Australia":"AU","Azerbaijan":"AZ",
  "Bahamas":"BS","Bahrain":"BH","Bangladesh":"BD","Barbados":"BB","Belarus":"BY",
  "Belgium":"BE","Benin":"BJ","Brazil":"BR","Canada":"CA","Catalonia":"ES",
  "Chile":"CL","China":"CN","Colombia":"CO","Croatia":"HR","Cuba":"CU","Cyprus":"CY",
  "Czech Republic":"CZ","Democratic Republic of the Congo":"CD","Denmark":"DK",
  "Ecuador":"EC","Egypt":"EG","Ethiopia":"ET","Finland":"FI","France":"FR",
  "French Polynesia":"PF","Ghana":"GH","Greece":"GR","Guam":"GU","Haiti":"HT",
  "Hungary":"HU","Iceland":"IS","India":"IN","Iran":"IR","Iraq":"IQ","Ireland":"IE",
  "Italy":"IT","Jamaica":"JM","Japan":"JP","Kuwait":"KW","Lebanon":"LB",
  "Malaysia":"MY","Mexico":"MX","Morocco":"MA","Myanmar":"MM","Nepal":"NP",
  "Netherlands":"NL","New Zealand":"NZ","Nigeria":"NG","North Korea":"KP",
  "Norway":"NO","Oman":"OM","Palestine":"PS","Panama":"PA","Peru":"PE",
  "Philippines":"PH","Poland":"PL","Romania":"RO","Russia":"RU","Rwanda":"RW",
  "Saudi Arabia":"SA","Slovakia":"SK","South Korea":"KR","Spain":"ES","Sri Lanka":"LK",
  "Sweden":"SE","Syria":"SY","Tanzania":"TZ","Turkey":"TR","Ukraine":"UA",
  "United Kingdom":"GB","United States of America":"US","Uruguay":"UY",
  "Uzbekistan":"UZ","Venezuela":"VE","Vietnam":"VN","Zimbabwe":"ZW",
};
const toFlag = (name: string) => {
  const code = COUNTRY_ISO[name];
  if (!code) return "🌍";
  return [...code].map(c => String.fromCodePoint(0x1F1E6 + c.charCodeAt(0) - 65)).join('');
};
const recentCountries = atw
  .filter(i => i.data.book_status === "DONE" && i.data.book_date_read)
  .sort((a, b) => b.data.book_date_read!.getTime() - a.data.book_date_read!.getTime())
  .slice(0, 3)
  .map(i => ({ name: i.data.location, flag: toFlag(i.data.location), id: i.id }));

const allNotebook = await getCollection("notebook");
const featuredMusings = allNotebook
  .filter((item) => "musings_edition" in item.data)
  .sort((a, b) => (b.data as any).musings_edition - (a.data as any).musings_edition)
  .slice(0, 2)
  .map((item) => ({
    title:   item.data.title,
    date:    item.data.last_modified.toLocaleDateString("en-US", { month: "long", year: "numeric" }),
    href:    `/notebook/${item.id}`,
    edition: (item.data as any).musings_edition as number,
  }));
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>maya sheth</title>
  <script type="module" src="/scripts/search-modal.js"></script>
  <script type="module" src="/scripts/mobile-menu.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300..600&family=Schibsted+Grotesk:ital,wght@0,375..600;1,375..600&family=Inconsolata:wght@300..600&display=swap&family=Playfair:ital,opsz,wght@0,5..1200,300..900;1,5..1200,300..900&display=swap"
    rel="stylesheet"
  />
  <style>
    /* Only things with no Tailwind equivalent */
    #hero, #content {
      position: relative;
      z-index: 1;
    }
    .glass {
      backdrop-filter: blur(20px) saturate(1.3);
      -webkit-backdrop-filter: blur(20px) saturate(1.3);
      border: 1px solid oklch(90.40% 0.017 264.38 / 0.08);
    }
    /* ── Hero photo ── */
    #hero-photo {
      width: clamp(9rem, 35vw, 14rem);
      height: clamp(9rem, 35vw, 14rem);
      flex-shrink: 0;
      border-radius: 50%;
      overflow: hidden;
      opacity: 0.88;
    }
    #hero-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 35%;
    }
    /* Panel zone labels — section titles that double as links */
    .zone-label, .zone-label-plain {
      display: block;
      font-family: var(--font-header);
      font-weight: var(--font-weight-semibold);
      font-size: var(--text-sm);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-surface-4);
      margin-bottom: 0.875rem;
      text-decoration: none;
    }
    .zone-label:hover {
      color: var(--color-content-2);
    }

    /* ── Label / heading shimmer ── */
    .zone-label-plain,
    .shimmer-heading {
      position: relative;
    }
    .zone-label-plain::after {
      content: attr(data-label);
      position: absolute;
      left: 0; top: 0; right: 0; bottom: 0;
      color: var(--card-accent, var(--color-accent-3));
      -webkit-mask-image: linear-gradient(90deg, black 0%, black 55%, transparent 100%);
      mask-image: linear-gradient(90deg, black 0%, black 55%, transparent 100%);
      -webkit-mask-size: 0% 100%;
      mask-size: 0% 100%;
      -webkit-mask-repeat: no-repeat;
      mask-repeat: no-repeat;
      -webkit-mask-position: 0% center;
      mask-position: 0% center;
      pointer-events: none;
    }
    @keyframes label-shimmer-in {
      from { mask-size: 0% 100%;   mask-position: 0% center; }
      to   { mask-size: 160% 100%; mask-position: 0% center; }
    }
    @keyframes label-shimmer-out {
      from { mask-size: 160% 100%; mask-position: 0% center; }
      to   { mask-size: 160% 100%; mask-position: 200% center; }
    }
    @keyframes label-breathe {
      0%   { opacity: 1; }
      20%  { opacity: 0.4; }
      100% { opacity: 1; }
    }
    @keyframes label-breathe-heading {
      0%   { opacity: 1; }
      30%  { opacity: 0.55; }
      100% { opacity: 1; }
    }
    .panel-card.shimmer-in .zone-label-plain {
      animation: label-breathe 3s ease-out forwards;
    }
    .shimmer-heading {
      transition: opacity 0.8s ease;
    }
    .shimmer-heading.shimmer-in {
      animation: label-breathe-heading 3s ease-out forwards;
    }
    .panel-card.shimmer-in .zone-label-plain::after {
      animation: label-shimmer-in 3s ease-out forwards;
    }
    .panel-card.shimmer-out .zone-label-plain::after {
      animation: label-shimmer-out 1.4s ease-out forwards;
    }

    /* ── Signature canvas ── */
    #sig-canvas {
      display: block;
      width: clamp(16rem, 60vw, 28rem);
      height: auto;
      opacity: 0.88;
    }

    /* Bottom "see all" CTA inside panels */
    .see-all {
      display: block;
      font-family: var(--font-header);
      font-weight: var(--font-weight-semibold);
      font-size: var(--text-sm);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-content-3);
      text-decoration: none;
      margin-top: auto;
      padding-top: 1rem;
      transition: color 0.4s ease, letter-spacing 0.4s ease;
    }
    .see-all:hover { color: var(--color-content-1); letter-spacing: 0.14em; }

    /* Column sub-headers inside panels */
    .col-label {
      display: block;
      font-family: var(--font-header);
      font-weight: var(--font-weight-semibold);
      font-size: var(--text-sm);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-surface-4);
      margin-bottom: 0.625rem;
    }
  </style>
</head>

<body class="bg-surface-0 overflow-x-hidden">

  <GradientBackground variant="full" />

  <Navigation />

  <!-- ── HERO ── photo + signature · text centered below both ─────────── -->
  <section id="hero" class="relative min-h-[52svh] flex items-center justify-center px-8 py-12">
    <div class="flex flex-col items-center gap-5">
      <h1 class="sr-only">maya sheth</h1>

      <!-- Row 1: photo and signature, vertically centred on the same axis -->
      <div class="flex flex-col md:flex-row items-center gap-6 md:gap-8">
        <div id="hero-photo">
          <img src="/banff-colored.jpeg" alt="Banff, Alberta" />
        </div>
        <canvas id="sig-canvas" aria-hidden="true"></canvas>
      </div>

      <!-- Row 2: who i am + science, centred below both elements -->
      <div class="flex flex-col items-center text-center gap-3 mt-1">

        <div>
          <h2 class="shimmer-heading text-xl text-content-1 mb-1">who i am</h2>
          <ul class="list-none flex flex-col gap-0.5 text-base leading-snug">
            <li class="font-base text-content-1">28 year old human</li>
            <li class="font-base text-content-2">asker of many questions (very skeptical)</li>
            <li class="font-base text-content-3">big fan of dogs, the ocean, sunshine, & coffee</li>
            <li class="font-base text-content-4">
              i write sporadic <a
                class="hover-stable text-content-3 hover:text-content-2 soft-transition focus-outline-rounded font-semibold hover:tracking-wide"
                data-text="musings"
                href="/musings">musings</a>; subscribe <span class="whitespace-nowrap"><a
                class="hover-stable text-content-3 hover:text-content-2 soft-transition focus-outline-rounded font-semibold hover:tracking-wide"
                data-text="here"
                href="https://airtable.com/appGBfUyNL8QylEWG/shrbJMCacQzWPrCLY"
                target="_blank"
                rel="noopener noreferrer">here</a></span>
            </li>
          </ul>
        </div>

        <div>
          <h2 class="shimmer-heading text-lg text-content-1 mb-1">also, science</h2>
          <ul class="list-none flex flex-col gap-0.5 text-base leading-snug">
            <li class="font-base text-content-1 lowercase">bioengineering PhD @ Stanford</li>
            <li class="font-base text-content-2">thinking about human gene regulation & modeling the noncoding genome</li>
            <li class="font-base text-content-3">
              more on my research <span class="whitespace-nowrap"><a
                class="hover-stable text-content-2 hover:text-content-3 soft-transition focus-outline-rounded font-semibold hover:tracking-wide"
                data-text="here"
                href="/portfolio/research">here</a></span>
            </li>
          </ul>
        </div>

      </div>

    </div>
  </section>

  <!-- ── PANELS — 12-col grid, panels can span multiple columns ───────────── -->
  <div id="content" class="grid grid-cols-12 gap-4 px-4 md:px-8 pb-20 mx-auto max-w-4xl">

    <!-- ── ROW 1: [artwork / worldly stacked] (7) | quotes (5) ── -->

    <div class="col-span-12 md:col-span-7 flex flex-col gap-4">

      <!-- artwork -->
      <div class="panel-card glass bg-surface-0/55 hover:bg-surface-0/40 transition-colors duration-[700ms] ease-in-out rounded-2xl p-5 relative overflow-hidden" style="--card-accent: var(--color-accent-3);">
        <div class="flex flex-col">
          <span class="zone-label-plain" data-label="artwork">artwork</span>
          <div class="grid grid-cols-3 gap-2">
            {featuredArtwork.map(art => (
              <a href="/portfolio/artwork" class="group relative block rounded-lg overflow-hidden aspect-square no-underline">
                {art.imgData && (
                  <Image
                    src={art.imgData}
                    alt={art.title ?? "artwork"}
                    class="w-full h-full object-cover"
                    widths={[240]}
                    sizes="240px"
                  />
                )}
                <div class="absolute inset-0 bg-surface-2/80 opacity-0 group-hover:opacity-100 soft-transition flex items-center justify-center p-2">
                  <span class="font-base text-sm text-content-1 lowercase leading-tight text-center">{art.title}</span>
                </div>
              </a>
            ))}
          </div>
          <a href="/portfolio/artwork" class="see-all">see all →</a>
        </div>
      </div>

      <!-- worldly -->
      <div class="panel-card glass bg-surface-0/55 hover:bg-surface-0/40 transition-colors duration-[700ms] ease-in-out rounded-2xl p-5 relative overflow-hidden" style="--card-accent: var(--color-accent-3);">
        <div class="flex flex-col">
          <span class="zone-label-plain" data-label="worldly">worldly</span>
          <p class="font-base font-light text-base text-content-3 leading-relaxed mb-2">
            a quest to read a book for every country in the world
          </p>
          <div class="flex items-center justify-between gap-4">
            <!-- 3-number stats -->
            <div class="flex items-baseline gap-2">
              <span class="font-base text-sm text-content-4">{atwBookIdea} ideas &middot;</span>
              <span class="font-serif font-extrabold text-3xl text-content-2 leading-none">{atwBookComplete}</span>
              <span class="font-base text-base text-content-3">read</span>
              <span class="font-base text-sm text-content-4">&middot; {atwToGo} to go</span>
            </div>
            <!-- recent countries -->
            <div class="flex flex-col gap-0.5 border-l border-surface-3 pl-4 shrink-0">
              {recentCountries.map(c => (
                <a href={`/media/around-the-world/${c.id}`} class="group flex items-center gap-1.5 no-underline">
                  <span class="text-base leading-none">{c.flag}</span>
                  <span class="font-base text-xs text-content-3 lowercase group-hover:text-content-1 soft-transition">{c.name}</span>
                </a>
              ))}
            </div>
          </div>
          <a href="/media/around-the-world" class="see-all">explore →</a>
        </div>
      </div>

    </div>

    <!-- quotes -->
    <div class="col-span-12 md:col-span-5">
      <div class="panel-card glass bg-surface-0/55 hover:bg-surface-0/40 transition-colors duration-[700ms] ease-in-out rounded-2xl p-5 h-full relative overflow-hidden" style="--card-accent: var(--color-accent-3);">
        <div class="h-full flex flex-col">
          <span class="zone-label-plain" data-label="quotes">quotes</span>
          <div class="flex flex-col gap-8">
            {featuredQuotes.map(q => (
              <a href={q.href} class="group block no-underline">
                <blockquote>
                  <p class={`${getQuoteClass(q.words)} lowercase soft-transition group-hover:text-content-0`}>{q.words}</p>
                  <cite class="not-italic block font-base font-semibold text-sm text-content-4 mt-2 lowercase soft-transition group-hover:text-content-3 group-hover:tracking-wide">— {q.source}</cite>
                </blockquote>
              </a>
            ))}
          </div>
          <a href="/quotes" class="see-all">see all →</a>
        </div>
      </div>
    </div>

    <!-- ── ROW 2: media strip (12) ── -->

    <div class="col-span-12">
      <div class="panel-card glass bg-surface-0/55 hover:bg-surface-0/40 transition-colors duration-[700ms] ease-in-out rounded-2xl px-5 py-3 relative overflow-hidden" style="--card-accent: var(--color-accent-3);">
        <div class="flex flex-col">
          <span class="zone-label-plain" data-label="media">media</span>
          <div class="grid grid-cols-2 md:grid-cols-5 gap-x-5 gap-y-2">
            {featuredMedia.map(m => (
              <a href={m.href} class="group block no-underline">
                <p class="font-base italic text-base text-content-1 leading-snug group-hover:text-content-0 group-hover:tracking-wide soft-transition lowercase">{m.title}</p>
                <p class="font-base font-light text-xs text-content-3/60 mt-0.5 lowercase tracking-wide">{m.author}</p>
              </a>
            ))}
          </div>
          <a href="/media" class="see-all">see all →</a>
        </div>
      </div>
    </div>

    <!-- ── ROW 3: musings (5) | interests (7) ── -->

    <div class="col-span-12 md:col-span-5">
      <div class="panel-card glass bg-surface-0/55 hover:bg-surface-0/40 transition-colors duration-[700ms] ease-in-out rounded-2xl p-5 h-full relative overflow-hidden" style="--card-accent: var(--color-accent-3);">
        <div class="h-full flex flex-col">
          <span class="zone-label-plain" data-label="maya's musings">maya's musings</span>
          <div class="flex flex-col gap-2">
            {featuredMusings.map(m => (
              <a href={m.href} class="group block no-underline relative" style="min-height: 4.5rem;">
                <span
                  aria-hidden="true"
                  class="absolute top-0 left-0 font-serif font-extrabold leading-none select-none pointer-events-none text-content-4/50 group-hover:text-content-3/60 soft-transition"
                  style="font-size: 4.25rem;"
                >{m.edition}</span>
                <div class="relative z-10 pt-5 pl-1">
                  <p class="font-base text-base text-content-1 leading-snug group-hover:text-content-0 group-hover:tracking-wide soft-transition lowercase">
                    {m.title}<span class="font-light text-sm text-content-4 ml-2 not-italic">{m.date}</span>
                  </p>
                </div>
              </a>
            ))}
          </div>
          <a href="/musings" class="see-all">see all →</a>
        </div>
      </div>
    </div>

    <div class="col-span-12 md:col-span-7">
      <div class="panel-card glass bg-surface-0/55 hover:bg-surface-0/40 transition-colors duration-[700ms] ease-in-out rounded-2xl p-5 h-full relative overflow-hidden" style="--card-accent: var(--color-accent-3);">
        <div class="h-full flex flex-col">
          <span class="zone-label-plain" data-label="currently into">currently into</span>
          <div class="flex flex-col gap-2">
            {currentInterests.map(i => (
              <p class="font-base text-base text-content-2 leading-snug lowercase">
                <span class="italic">{i.title}</span>
                {i.descriptionParts
                  ? <span class="font-light text-content-3">: {i.descriptionParts.map((part: { text: string; href?: string }) =>
                      part.href
                        ? <a href={part.href} target="_blank" rel="noopener noreferrer" class="hover-stable font-semibold text-content-2 hover:text-content-1 soft-transition focus-outline-rounded hover:tracking-wide" data-text={part.text}>{part.text}</a>
                        : part.text
                    )}</span>
                  : i.description && <span class="font-light text-content-3">: {i.description}</span>
                }
              </p>
            ))}
            {currently.learning.map((item: { title: string; href: string | null }) => (
              <p class="font-base text-base text-content-2 leading-snug lowercase">
                {item.title} <span class="font-light text-content-3">(very early stages)</span>
              </p>
            ))}
          </div>
          <p class="font-mono text-xs text-content-3/70 mt-auto pt-4 self-end">updated {currently.lastUpdated}</p>
        </div>
      </div>
    </div>

    <!-- ── ROW 4: also (narrower, centered) ── -->

    <div class="col-span-12 md:col-span-8 md:col-start-3">
      <div class="panel-card glass bg-surface-0/55 hover:bg-surface-0/40 transition-colors duration-[700ms] ease-in-out rounded-2xl p-5 h-full relative overflow-hidden" style="--card-accent: var(--color-accent-3);">
        <div class="h-full">
          <span class="zone-label-plain" data-label="also">also</span>
          <div class="flex flex-col gap-0.5 items-center text-center">
            <a href="/gratitudes" class="group block no-underline py-2">
              <p class="font-header font-semibold text-base text-content-2 tracking-wide group-hover:text-content-0 group-hover:tracking-wider soft-transition">gratitudes</p>
              <p class="font-base font-light text-sm text-content-4 mt-0.5 leading-snug">things that make me smile</p>
            </a>
            <a href="/portfolio/design" class="group block no-underline py-2">
              <p class="font-header font-semibold text-base text-content-2 tracking-wide group-hover:text-content-0 group-hover:tracking-wider soft-transition">design</p>
              <p class="font-base font-light text-sm text-content-4 mt-0.5 leading-snug">typography, branding, interface experiments</p>
            </a>
            <a href="/notebook" class="group block no-underline py-2">
              <p class="font-header font-semibold text-base text-content-2 tracking-wide group-hover:text-content-0 group-hover:tracking-wider soft-transition">notebook</p>
              <p class="font-base font-light text-sm text-content-4 mt-0.5 leading-snug">structured + freeform thoughts, questions, & common themes</p>
            </a>
          </div>
        </div>
      </div>
    </div>

  </div>

  <Footer />

  <script>
    // ── Canvas signature renderer ──────────────────────────────────────────────
    {
      const canvas = document.getElementById("sig-canvas");
      const ctx = canvas.getContext("2d");
      const SVG_W = 355.06, SVG_H = 216.82;
      const dpr = (window.devicePixelRatio || 1) * 2; // 2× oversampling for crisp zoom
      canvas.width  = Math.round(SVG_W * dpr);
      canvas.height = Math.round(SVG_H * dpr);
      ctx.scale(dpr, dpr);

      // 4 letter strokes + 13 koala detail paths (from public/ms-signature-v1.svg)
      const PATH_STRINGS = [
        // maya "M"
        "M29.34,82.89c12.82-13.86,28.41-25.16,45.58-33.02.76,2.12-.32,4.42-1.36,6.41-11.37,21.6-22.75,43.19-34.12,64.79,17.49-25.37,35.25-51.05,58.65-71.09-14.62,23.08-19.67,33.06-18.26,34.1,3.7,2.75,52.91-55.04,50.91-56.94-.8-.76-10.19,7.22-16.97,14.36-21.11,22.19-44.95,65.38-30.52,85.09,11.03,15.07,40.44,10.99,76.88,5.94,25.82-3.58,46.78-10.14,61.49-15.7",
        // aya
        "M105.66,93.85c-1.06-.28-6.8-1.71-11.45,1.69-4.09,2.99-5.92,8.69-4.69,9.74,1.38,1.17,6.95-3.16,9.12-5.02,5.2-4.45,7.52-8.96,8.09-8.65.93.5-5.33,12.43-3.97,13.3,1.78,1.15,15.41-17.77,17.18-16.62,1.31.85-5.71,11.57-3.35,13.42,2,1.58,8.44-2.8,12.28-7.19,4.42-5.05,5.9-10.7,6.46-14.03-13.15,21.8-9.42,49.63-16.63,74.05-2.51,8.5-7.38,17.49-15.94,19.79-2.39.64-5.07.65-7.18-.64-2.88-1.77-3.92-5.43-4.32-8.79-2.56-21.82,16.61-43.79,16.61-43.79,18.14-20.58,39.76-26.39,38.79-28.53-.57-1.25-8.31-.3-10.73,4.05-1.51,2.71-.85,6.53.3,6.87.91.28,2.04-1.5,4.72-4.25.96-.99,2.56-2.29,5.16-3.28-1.99,4.28-2.55,6.76-1.68,7.45,1.26,1,5.55-1.8,12.87-8.41",
        // sheth "S"
        "M190.22,47.39c-1.79-4.92-4.74-9.42-8.54-13.02-1.85-1.75-3.98-3.33-6.45-3.95-6.39-1.61-12.82,3.98-14.45,10.36s.26,13.09,2.45,19.3c1.93,5.47,4.1,10.86,6.5,16.14,2.38,5.22,4.99,10.37,6.54,15.89s1.98,11.55-.04,16.91-6.83,9.9-12.53,10.46-11.79-3.72-12.21-9.44",
        // heth
        "M201.65,53.87c-11.69,32.13-23.3,64.56-22.58,64.83.62.24,10.38-23.7,14.61-22.53,1.97.54,1.29,6.11,4.14,7.01,2.62.82,5.95-2.86,8.39-5.58,3.11-3.46,7.09-7.88,5.87-12.59-.54-2.1-2.22-4.67-3.67-4.49-3.58.45-2.71,17.39-.9,24.18.31,1.16.88,2.89,2.23,3.38,1.73.62,3.8-1.09,4.58-1.74,5.64-4.67,21.71-42.67,24.98-50.44-5.5,17.07-10.41,34.32-14.74,51.72-.27,1.09-.5,2.35.19,3.23,1.21,1.54,3.66.38,5.15-.89,15.58-13.4,26.1-32.54,29.08-52.87-3.88,6.97-7.91,15.25-11.53,24.8-4.14,10.95-6.79,21.06-8.51,29.75,1.52-4.39,3.32-7.85,4.88-10.43,1.68-2.77,3.83-6.23,5.45-5.87,1.48.33.66,3.54,3.05,6.13,2.97,3.22,8.46,2.61,9.27,2.51,8.14-.96,15.07-9.61,13.45-13.58-.56-1.37-2.04-2.03-4.31-2.69-6.67-1.94-13.7-2.15-20.56-3.28,0,0-10.09-1.22-18.61-8.49-12.22-10.43-11.27-29.18-10.94-33.49",
        // koala (13 short detail paths)
        "M283.41,84.54l6.38,4.05",
        "M287.8,75.62c.26,4.32,1.77,8.55,4.28,12.07",
        "M292.36,68.6v14.88",
        "M299.76,77.6c-.28,2.33-1.03,4.61-2.2,6.65",
        "M318.58,83.15c1.09-4.14,1.93-8.34,2.52-12.58",
        "M322.55,85.06c2.55-3.32,5.33-6.47,8.32-9.4",
        "M324.95,86.36l9.25-1.24",
        "M323.25,90.22h4.49",
        "M306.4,95.26c1.34-.16,2.64-.63,3.77-1.36-2.32-.47-4.84.17-6.65,1.68,1.16,1.3,3.34,1.53,4.73.48",
        "M306.24,97.52c.23,1.9.45,3.83.09,5.71s-1.39,3.73-3.1,4.58-4.11.41-5.03-1.26",
        "M307.22,98.64c-.41,1.78.37,3.78,1.88,4.81s3.66,1.02,5.16-.03",
        "M300.49,88c.2.1.45.08.64-.03-.14-.11-.29-.23-.47-.25s-.39.11-.39.29c0,.24.31.33.55.3",
        "M310.52,87.01c.11.09.3-.04.29-.18s-.16-.25-.31-.23-.26.12-.33.24c-.1.17-.12.4,0,.56s.37.21.51.08",
      ];

      // Off-screen SVG to measure path lengths and sample points
      const _svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
      _svg.style.cssText = "position:absolute;visibility:hidden;pointer-events:none;width:0;height:0;overflow:hidden";
      document.body.appendChild(_svg);

      const _cvs = Object.assign(document.createElement("canvas"), { width: 1, height: 1 });
      const _ctx2d = _cvs.getContext("2d");
      function toRgba(cssColor: string): [number, number, number, number] {
        _ctx2d!.clearRect(0, 0, 1, 1);
        _ctx2d!.fillStyle = cssColor;
        _ctx2d!.fillRect(0, 0, 1, 1);
        const d = _ctx2d!.getImageData(0, 0, 1, 1).data;
        return [d[0]/255, d[1]/255, d[2]/255, d[3]/255];
      }

      // Letters: teal → cycling accent; koala: teal shade → teal shade
      const TEAL        = toRgba("oklch(79% 0.140 172)");   // teal    #3dd5a9
      const ACCENT_LIST = [
        toRgba("oklch(43% 0.220 303)"),  // purple  #8345b6
        toRgba("oklch(47% 0.260 333)"),  // magenta #b11e85
        toRgba("oklch(78% 0.175  68)"),  // amber   #feb43a
      ];
      const KOALA_TEALS = [
        toRgba("oklch(82% 0.10 180)"),   // pale teal
        toRgba("oklch(72% 0.14 188)"),   // bright teal
        toRgba("oklch(63% 0.16 196)"),   // mid teal
        toRgba("oklch(53% 0.17 206)"),   // deep teal
        toRgba("oklch(46% 0.15 216)"),   // teal-blue
      ];

      function strokeColor(from, to, t) {
        const r  = Math.round((from[0] + (to[0] - from[0]) * t) * 255);
        const g  = Math.round((from[1] + (to[1] - from[1]) * t) * 255);
        const bv = Math.round((from[2] + (to[2] - from[2]) * t) * 255);
        return `rgb(${r},${g},${bv})`;
      }

      const paths = PATH_STRINGS.map((d, i) => {
        const el = document.createElementNS("http://www.w3.org/2000/svg", "path");
        el.setAttribute("d", d);
        _svg.appendChild(el);
        let colorStart, colorEnd;
        if (i >= 4) {
          const ki = i - 4;
          colorStart = KOALA_TEALS[ki % KOALA_TEALS.length];
          colorEnd   = KOALA_TEALS[(ki + 2) % KOALA_TEALS.length];
        } else {
          colorStart = TEAL;
          colorEnd   = ACCENT_LIST[i % ACCENT_LIST.length];
        }
        return { el, len: el.getTotalLength(), isKoala: i >= 4, colorStart, colorEnd };
      });

      // Explicit time budgets per stroke (fraction of TOTAL_MS).
      // Koala paths share the remaining 0.30, proportional to their lengths.
      const LETTER_BUDGETS = [0.09, 0.28, 0.06, 0.27]; // M, aya, S, heth — S +12% slower
      const KOALA_START    = 0.70; // = sum of LETTER_BUDGETS

      const letterPaths = paths.filter(p => !p.isKoala);
      const koalaPaths  = paths.filter(p =>  p.isKoala);

      let tCum = 0;
      for (let i = 0; i < letterPaths.length; i++) {
        letterPaths[i].tStart = tCum;
        letterPaths[i].tEnd   = tCum + LETTER_BUDGETS[i];
        tCum += LETTER_BUDGETS[i];
      }

      const koalaLen = koalaPaths.reduce((s, p) => s + p.len, 0);
      let cum = 0;
      for (const p of koalaPaths) {
        p.tStart = KOALA_START + (cum / koalaLen) * (1 - KOALA_START);
        p.tEnd   = KOALA_START + ((cum + p.len) / koalaLen) * (1 - KOALA_START);
        cum += p.len;
      }

      // Letters: round-brush — pressure envelope dominates, direction gives subtle ±25% swell
      function letterWidth(dx, dy, base, pathT) {
        const pressure = Math.pow(Math.sin(Math.PI * pathT), 0.33); // swells through mid-stroke
        const len = Math.sqrt(dx * dx + dy * dy);
        const normalizedDy = len > 0.001 ? dy / len : 0; // -1 upstroke → +1 downstroke
        const dirBias = 1 + 0.25 * normalizedDy; // 0.75× upstroke, 1.25× downstroke
        return Math.max(0.4, base * pressure * dirBias);
      }
      // Koala: wide at stroke start, taper to a point at end
      function koalaWidth(pathT, base) {
        return Math.max(0.2, base * (1 - pathT));
      }

      const TOTAL_MS = 8000;
      const SEG_LEN  = 2.5; // SVG units per drawn segment
      let startTime  = null;

      function frame(now) {
        if (!startTime) startTime = now;
        const progress = Math.min((now - startTime) / TOTAL_MS, 1);

        ctx.clearRect(0, 0, SVG_W, SVG_H);
        ctx.lineCap = "round";

        for (const p of paths) {
          if (progress <= p.tStart) continue;
          const pathProgress = Math.min((progress - p.tStart) / (p.tEnd - p.tStart), 1);
          const drawnLen = p.len * pathProgress;
          const nSeg = Math.max(1, Math.ceil(drawnLen / SEG_LEN));
          const base = p.isKoala ? 1.75 : 3.5;

          for (let s = 0; s < nSeg; s++) {
            const l0 = (s / nSeg) * drawnLen;
            const l1 = ((s + 1) / nSeg) * drawnLen;
            const pt0 = p.el.getPointAtLength(l0);
            const pt1 = p.el.getPointAtLength(l1);
            const pathT = l0 / p.len;
            const dx = pt1.x - pt0.x;
            const dy = pt1.y - pt0.y;
            ctx.beginPath();
            ctx.moveTo(pt0.x, pt0.y);
            ctx.lineTo(pt1.x, pt1.y);
            ctx.lineWidth   = p.isKoala ? koalaWidth(pathT, base) : letterWidth(dx, dy, base, pathT);
            ctx.strokeStyle = strokeColor(p.colorStart, p.colorEnd, pathT);
            ctx.stroke();
          }
        }

        if (progress < 1) requestAnimationFrame(frame);
      }

      requestAnimationFrame(frame);
    }

    // ── Card label / heading shimmer ───────────────────────────────────────
    function attachShimmer(el) {
      el.addEventListener('mouseenter', () => {
        el.classList.remove('shimmer-out');
        void el.offsetWidth;
        el.classList.add('shimmer-in');
      });
      el.addEventListener('mouseleave', () => {
        el.classList.remove('shimmer-in');
        void el.offsetWidth;
        el.classList.add('shimmer-out');
      });
    }
    document.querySelectorAll('.panel-card').forEach(attachShimmer);
    document.querySelectorAll('.shimmer-heading').forEach(attachShimmer);

  </script>

