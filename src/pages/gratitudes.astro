---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import MasonryGrid from "@/components/ui/MasonryGrid.astro";
import { getCollection } from "astro:content";

const titleShort = ":)";
const titleFull = "thank you, world";

const gratitudes = await getCollection("gratitudes");

gratitudes.sort((a, b) =>
  new Date(b.data.relevant_date) > new Date(a.data.relevant_date) ? 1 : -1,
);


function formatDate(date: Date): string {
  const newDate = new Date(date);
  const year = newDate.getFullYear();
  const month = String(newDate.getMonth() + 1).padStart(2, "0");
  const day = String(newDate.getDate()).padStart(2, "0");
  return `${year}/${month}/${day}`;
}

const imageImports = import.meta.glob<{ default: ImageMetadata }>(
  "../content/300-collections/gratitudes/images/*",
);

const itemsWithImageImports = await Promise.all(
  gratitudes.map(async (item) => {
    let imgSrc = null;
    if (item.data.image) {
      const imageFileName = item.data.image.replace(/^\.\.\/images\//, "");
      const globKey = `../content/300-collections/gratitudes/images/${imageFileName}`;
      if (imageImports[globKey]) {
        imgSrc = (await imageImports[globKey]()).default;
      } else {
        console.warn("Image not found via import.meta.glob mapping:", globKey);
      }
    }
    return { ...item, imgSrc };
  }),
);
---

<BaseLayout titleShort={titleShort} titleFull={titleFull}>
  <p class="text-content-1 pb-8 text-center font-base font-light">
    (smile-inducing, gratitude-provoking, and otherwise noteworthy moments)
  </p>

  <MasonryGrid cols={2} colsSm={3} colsLg={4} gap="0.75rem" class="mx-auto max-w-5xl px-4 pb-12">
    {
      itemsWithImageImports.map((item, index) => (
        <masonry-item
          id={item.id}
          class="flex justify-center"
          data-pagefind-body
          data-pagefind-title={item.data.redacted_content}
          data-pagefind-url={`/gratitudes#${item.id}`}
        >
          {item.imgSrc ? (
            <div class="img-orb w-full aspect-square rounded-full overflow-hidden group relative opacity-0">
              <Image
                src={item.imgSrc}
                alt={item.data.redacted_content}
                width={300}
                draggable="false"
                loading={index < 12 ? "eager" : "lazy"}
                class="h-full w-full object-cover"
              />
              <div class="img-orb-overlay absolute inset-0 flex flex-col items-center justify-center bg-surface-0/80 p-6 text-center opacity-0 soft-transition group-hover:opacity-100">
                <p class="text-content-1 font-base font-light text-sm lowercase leading-tight line-clamp-5">
                  {item.data.redacted_content}
                </p>
                <span class="text-content-3 mt-1.5 font-mono text-[0.6rem]">
                  {formatDate(item.data.relevant_date)}
                </span>
              </div>
            </div>
          ) : (
            <div class="text-orb rounded-full overflow-hidden soft-transition flex flex-col items-center justify-center gap-0.5 p-3 sm:p-5 lg:p-7 opacity-0">
              <p class="text-sm text-content-2 text-center font-base font-light lowercase leading-snug">
                {item.data.redacted_content}
              </p>
              <span class="text-content-3 mt-0.5 font-mono text-[0.6rem] leading-none">
                {formatDate(item.data.relevant_date)}
              </span>
            </div>
          )}
        </masonry-item>
      ))
    }
  </MasonryGrid>

  <style is:global>
    /* Animate the radial gradient focal point per-orb.
       @property is required so the browser can interpolate --gx/--gy. */
    @property --gx { syntax: '<percentage>'; inherits: false; initial-value: 38%; }
    @property --gy { syntax: '<percentage>'; inherits: false; initial-value: 32%; }

    @keyframes drift-highlight {
      0%   { --gx: 34%; --gy: 28%; }
      25%  { --gx: 48%; --gy: 22%; }
      55%  { --gx: 44%; --gy: 46%; }
      80%  { --gx: 26%; --gy: 40%; }
      100% { --gx: 34%; --gy: 28%; }
    }

    .text-orb {
      background: radial-gradient(
        circle at var(--gx) var(--gy),
        var(--orb-hi, var(--color-surface-3)),
        var(--orb-lo, var(--color-surface-1))
      );
      animation: drift-highlight var(--orb-dur, 6s) ease-in-out infinite;
      animation-delay: var(--orb-delay, 0s);
    }

    .text-orb:hover { filter: brightness(1.28); }
  </style>

  <script>
    function sizeOrbs(): void {
      const orbs = Array.from(
        document.querySelectorAll(".text-orb") as NodeListOf<HTMLElement>
      );
      if (!orbs.length) return;

      // Read: get max size (= column width) for each orb — one reflow
      const maxSizes = orbs.map(
        (orb) => (orb.closest("masonry-item") as HTMLElement)?.offsetWidth ?? 200
      );
      const minSize = 88;
      const los = new Array(orbs.length).fill(minSize);
      const his = [...maxSizes];

      // Write: unconstrain height, set width to max so text wraps freely
      orbs.forEach((orb, i) => {
        orb.style.height = "auto";
        orb.style.width = maxSizes[i] + "px";
      });

      // 8 binary search iterations, each costing one reflow (batched reads)
      for (let iter = 0; iter < 8; iter++) {
        // Write phase: all orbs get new trial width
        orbs.forEach((orb, i) => {
          orb.style.width = Math.round((los[i] + his[i]) / 2) + "px";
        });
        // Read phase: one reflow, then cached for remaining reads
        orbs.forEach((orb, i) => {
          const mid = Math.round((los[i] + his[i]) / 2);
          if (orb.scrollHeight <= mid) his[i] = mid;
          else los[i] = mid;
        });
      }

      // Write: apply final size with breathing room (~12% of column), capped at column width
      orbs.forEach((orb, i) => {
        const extra = Math.round(maxSizes[i] * 0.12);
        const size = Math.min(his[i] + extra, maxSizes[i]);
        orb.style.width = size + "px";
        orb.style.height = size + "px";
      });
    }

    const isTouch = window.matchMedia("(hover: none)").matches;

    // Touch: tap to show/hide overlay on image orbs (no hover on mobile)
    if (isTouch) {
      document.querySelectorAll(".img-orb").forEach((orb) => {
        const overlay = orb.querySelector(".img-orb-overlay") as HTMLElement | null;
        if (!overlay) return;
        orb.addEventListener("click", () => {
          const shown = overlay.style.opacity === "1";
          overlay.style.opacity = shown ? "0" : "1";
        });
      });
    }

    // --- Physics: idle drift + mouse repulsion ---
    const REPEL_RADIUS = 130;
    const REPEL_STRENGTH = 1.4;
    const SPRING_K = 0.07;
    const DAMPING = 0.82;
    const MAX_DISP = 20;

    type PhysOrb = {
      el: HTMLElement;
      x: number; y: number;
      vx: number; vy: number;
      dax: number; day: number;
      dfx: number; dfy: number;
      dpx: number; dpy: number;
    };

    let orbStates: PhysOrb[] = [];
    let mouseX = -9999;
    let mouseY = -9999;
    let rafId = 0;

    function makeOrbState(el: HTMLElement, prev?: PhysOrb): PhysOrb {
      // Override soft-transition's transition-all so transform updates are instant
      el.style.transition = "opacity 400ms ease, filter 300ms ease";
      return {
        el,
        x: 0, y: 0, vx: 0, vy: 0,
        dax: prev?.dax ?? 2 + Math.random() * 2,
        day: prev?.day ?? 2 + Math.random() * 2,
        dfx: prev?.dfx ?? (0.25 + Math.random() * 0.30) * 2 * Math.PI,
        dfy: prev?.dfy ?? (0.25 + Math.random() * 0.30) * 2 * Math.PI,
        dpx: prev?.dpx ?? Math.random() * 2 * Math.PI,
        dpy: prev?.dpy ?? Math.random() * 2 * Math.PI,
      };
    }

    function initPhysics(): void {
      const allOrbs = Array.from(document.querySelectorAll<HTMLElement>(".text-orb, .img-orb"));
      orbStates = allOrbs.map((el) => makeOrbState(el));
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(loop);
    }

    function reinitPhysics(): void {
      const allOrbs = Array.from(document.querySelectorAll<HTMLElement>(".text-orb, .img-orb"));
      const prevMap = new Map(orbStates.map((s) => [s.el, s]));
      orbStates = allOrbs.map((el) => makeOrbState(el, prevMap.get(el)));
    }

    function loop(timestamp: number): void {
      const t = timestamp / 1000;

      // Read phase: batch all getBoundingClientRect calls before any writes
      const rects = orbStates.map((s) => s.el.getBoundingClientRect());

      // Compute + Write phase
      for (let i = 0; i < orbStates.length; i++) {
        const s = orbStates[i];
        const rect = rects[i];

        // Idle drift (sinusoidal, always runs including mobile)
        const driftX = s.dax * Math.sin(t * s.dfx + s.dpx);
        const driftY = s.day * Math.cos(t * s.dfy + s.dpy);

        // Spring repulsion from cursor (non-touch only)
        if (!isTouch) {
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;
          const dx = cx - mouseX;
          const dy = cy - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < REPEL_RADIUS && dist > 0) {
            const force = (1 - dist / REPEL_RADIUS) * REPEL_STRENGTH;
            s.vx += (dx / dist) * force;
            s.vy += (dy / dist) * force;
          }
        }

        // Spring return + damping
        s.vx += -s.x * SPRING_K;
        s.vy += -s.y * SPRING_K;
        s.vx *= DAMPING;
        s.vy *= DAMPING;
        s.x += s.vx;
        s.y += s.vy;
        s.x = Math.max(-MAX_DISP, Math.min(MAX_DISP, s.x));
        s.y = Math.max(-MAX_DISP, Math.min(MAX_DISP, s.y));

        // Write transform (drift + spring displacement)
        s.el.style.transform = `translate(${(s.x + driftX).toFixed(2)}px, ${(s.y + driftY).toFixed(2)}px)`;
      }

      rafId = requestAnimationFrame(loop);
    }

    // Mouse tracking (non-touch only); off-page coords disable repulsion
    if (!isTouch) {
      document.addEventListener("mousemove", (e) => { mouseX = e.clientX; mouseY = e.clientY; });
      document.addEventListener("mouseleave", () => { mouseX = -9999; mouseY = -9999; });
    }

    // Pause loop when tab is hidden, resume when visible
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) cancelAnimationFrame(rafId);
      else rafId = requestAnimationFrame(loop);
    });

    // Assign per-orb gradient colours and animation timing (runs once at init)
    function stylizeOrbs(): void {
      const orbs = Array.from(document.querySelectorAll<HTMLElement>(".text-orb"));
      // Gradient tiers: [hi-lightness, hi-chroma, lo-lightness, lo-chroma]
      const tiers = [
        [41,   0.10, 14.2, 0.07],  // bright + deep
        [38.2, 0.10, 22.8, 0.07],  // mid
        [38.2, 0.09, 14.2, 0.07],  // mid + deep
        [34,   0.09, 27,   0.09],  // low contrast
      ] as const;
      orbs.forEach(el => {
        const baseHue = 230 + Math.random() * 18;              // 230–248°
        const hiHue   = baseHue + (Math.random() - 0.5) * 8;  // ±4° jitter
        const loHue   = hiHue + 8 + Math.random() * 6;        // lo is 8–14° deeper
        const [hiL, hiC, loL, loC] = tiers[Math.floor(Math.random() * tiers.length)];
        el.style.setProperty("--orb-hi", `oklch(${hiL}% ${hiC} ${hiHue.toFixed(1)})`);
        el.style.setProperty("--orb-lo", `oklch(${loL}% ${loC} ${loHue.toFixed(1)})`);
        el.style.setProperty("--orb-dur",   `${(5 + Math.random() * 3).toFixed(1)}s`);
        el.style.setProperty("--orb-delay", `-${(Math.random() * 8).toFixed(1)}s`);
      });
    }

    // Run after layout settles; re-run on resize
    requestAnimationFrame(() => requestAnimationFrame(() => {
      sizeOrbs();
      stylizeOrbs();
      initPhysics(); // sets opacity transition on each orb
      // Reveal orbs in the next frame so the transition actually fires (0→1)
      requestAnimationFrame(() => {
        orbStates.forEach(s => { s.el.style.opacity = "1"; });
      });
    }));
    let _t: ReturnType<typeof setTimeout>;
    window.addEventListener("resize", () => {
      clearTimeout(_t);
      _t = setTimeout(() => {
        sizeOrbs();
        reinitPhysics();
      }, 150);
    });
  </script>
</BaseLayout>
